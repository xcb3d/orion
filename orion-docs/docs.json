        "description": "Browser extension architecture, crypto engine, and integrations",
        "icon": "Puzzle",
        "groups": [
          {
            "label": "Core",
            "pages": [
              { "file": "extension/overview" },
              { "file": "extension/background" },
              { "file": "extension/crypto-engine" },
              { "file": "extension/walrus" }
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "text": "Built with cmdocs",
