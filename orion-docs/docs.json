  "favicon": "/favicon.svg",
  "theme": {
    "preset": "neutral",
    "colors": {
      "primary": "#10B981"
    },
    "darkMode": true,
    "breadcrumb": true,
    "lastUpdated": true
  },
  "seo": {
    "title": "Orion Developer Portal",
    "titleTemplate": "%s — Orion",
    "description": "Documentation for the Orion Password Manager — a zero-knowledge, decentralized credential manager built on Sui."
  },
  "navbar": {
    "title": "Orion",
    "logo": {
      "light": "/logo/light-logo-only.svg",
      "dark": "/logo/dark-logo-only.svg",
      "display": "brand-name-and-logo"
    },
    "github": "https://github.com/orion-passman",
    "links": []
  },
  "navigation": {
    "tabs": [
      {
        "label": "Architecture",
        "path": "architecture",
        "description": "System architecture, security model, and authentication flow",
        "icon": "Box",
